Import('env', 'arch')

# 确保工具目录存在并编译
tools_replay_dir = Dir('#tools/replay').abspath
import os
if os.path.exists(os.path.dirname(tools_replay_dir)):
  # 强制编译tools/replay，不依赖于extras选项
  SConscript(['#tools/replay/SConscript'])

env.Command(
  target=['broadcast'],
  source=['broadcast.py'],
  action='touch $TARGET && cp $SOURCE $TARGET && chmod +x $TARGET'
)

Return()